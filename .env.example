# Discord bot token (same bot as OSINT, different server)
DISCORD_BOT_TOKEN="your_discord_bot_token_here"

# X API (bearer token from your X Developer project)
X_BEARER_TOKEN="your_x_bearer_token_here"

# Anthropic API key (Claude)
ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# Tavily API key (web search)
TAVILY_API_KEY="your_tavily_api_key_here"

# Claude model
CLAUDE_MODEL="claude-4-sonnet-20250514"

# Timezone for scheduled digests
TIMEZONE="America/Chicago"

# Database path (set to Railway volume mount for persistence)
# DB_PATH="/data/bot_data.db"

# Discord user ID for server ownership transfer (setup script only)
# OWNER_USER_ID="123456789012345678"
